{
  "manifest_version": 3,
  "name": "Price Checker",
  "version": "1.1.2",
  "description": "Compare product prices between UK and Israel retail websites",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.next.co.uk/*",
    "https://www.next.co.il/*",
    "https://core.dxpapi.com/*",
    "https://www.zara.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
